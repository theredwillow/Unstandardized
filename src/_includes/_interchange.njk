<svg viewBox="0 0 800 200" xmlns="http://www.w3.org" class="interchange-canvas">
  <!-- Render Roads -->
  {% for road in interchange.roadways %}
    <path id="{{ interchange.id }}-{{ road.id }}" class="road-base type-{{ road.type }}" d="{{ road.path }}" stroke-width="{{ road.width }}" />
  {% endfor %}

  <!-- Add invisible paths for motorists to travel between roads -->
  {% for route in interchange.routes %}
    <path id="{{ interchange.id }}-{{ route.id }}" class="route" d="{{ route.path }}" />
  {% endfor %}

  <!-- Render Traffic -->
  {% for vehicle in interchange.traffic %}
    <use href="#v-{{ vehicle.type }}" 
         class="vehicle {{ vehicle.type }}"
         y="-10"
         fill="{{ vehicle.behavior.color }}">
      <animateMotion dur="{{ vehicle.behavior.speed }}" begin="{{ vehicle.behavior.delay }}" repeatCount="indefinite" rotate="auto">
        <mpath href="#{{ interchange.id }}-{{ vehicle.roadway }}" />
      </animateMotion>
    </use>
  {% endfor %}
</svg>
