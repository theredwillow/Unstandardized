<div id="confucius">
  <div class="content" onclick="nextStep()">
    <div class="active">Confucius once said...</div>

    <div>By three methods, we may learn wisdom.</div>

    <div class="method">
      <div class="number">1st</div>
      <div class="nominal-verb">Reflection</div>
      <div class="which-is">which is</div>
      <div class="superlative">noblest</div>
    </div>

    <div class="method">
      <div class="number">2nd</div>
      <div class="nominal-verb">Imitation</div>
      <div class="which-is">which is</div>
      <div class="superlative">easiest</div>
    </div>

    <div class="method">
      <div class="number">3rd</div>
      <div class="nominal-verb">Experience</div>
      <div class="which-is">which is</div>
      <div class="superlative">bitterest</div>
    </div>
  </div>

