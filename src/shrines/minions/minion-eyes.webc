<script src="minion-eyes.js" defer></script>

<svg
  class="minion-eyes"
  width="100mm"
  height="50mm"
  viewBox="0 0 100 50"
  version="1.1"
  xmlns="http://www.w3.org/2000/svg"
  xmlns:svg="http://www.w3.org/2000/svg"
>
  <g class="eye">
    <circle class="eye-lid" cx="25" cy="25" r="20" />
    <ellipse class="eye-white" cx="25" cy="25" rx="20" />
    <circle class="eye-frame" cx="25" cy="25" r="20" />
  </g>
</svg>
